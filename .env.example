# 可选：真实 LLM（OpenAI 兼容接口，含 DeepSeek 等）
# 复制为 .env 后填入密钥。无 Key 时 customer_service 可走离线降级。
OPENAI_API_KEY=sk-...
# DeepSeek 示例：
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-v4-flash
# OpenAI 示例：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# customer_service 配置（均可选，有默认值）
# ALLOW_OFFLINE_FALLBACK=true
# CHECKPOINTER_BACKEND=memory
# CHECKPOINTER_SQLITE_PATH=data/checkpoints.sqlite
# TICKETS_DB_PATH=data/tickets.db
# CUSTOMER_SERVICE_DATA_DIR=data
# KNOWLEDGE_DIR=
# 客服对接自研 RAG（统一服务默认同端口 8000；默认 local；验收后可改 http）
# RAG_PROVIDER=http
# RAG_BASE_URL=http://127.0.0.1:8000
# RAG_KB_ID=kb_default
# RAG_TOP_K=5
# RAG_RERANK=false
# RAG_API_KEY=
# RAG 中台（可选）
# RAG_DATA_DIR=data/rag
# RAG_DB_PATH=data/rag/rag.db
# RAG_FILES_DIR=data/rag/files
# RAG_MAX_UPLOAD_BYTES=2097152
# RAG_ALLOWED_EXTENSIONS=.md,.txt
# RAG_DEFAULT_KB_ID=kb_default
# RAG_DEFAULT_KB_NAME=default
# 切片
# RAG_CHUNK_TOKEN_NUM=512
# RAG_CHUNK_OVERLAP_PERCENT=10
# Embedding（可与 OPENAI_* 聊天配置分离；DeepSeek 无 embeddings 时必填）
# RAG_EMBEDDING_API_KEY=sk-...
# RAG_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# RAG_EMBEDDING_MODEL=BAAI/bge-m3
# Rerank（硅基流动 /rerank；默认复用 embedding 的 Key/Base）
# RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RAG_RERANK_API_KEY=
# RAG_RERANK_BASE_URL=https://api.siliconflow.cn/v1
# 亦可用：SILICONFLOW_API_KEY / SILICONFLOW_BASE_URL
